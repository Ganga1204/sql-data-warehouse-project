        try_cast(sls_ship_dt as date)                as ship_date,
        try_cast(sls_due_dt as date)                 as due_date,
        sls_sales                                    as sales_amount,
        sls_quantity                                 as quantity,
        sls_price                                    as unit_price,
        case
            when sls_ship_dt is null
              or sls_order_dt is null then null
            else datediff(
                day,
                try_cast(sls_order_dt as date),
                try_cast(sls_ship_dt as date)
            )
        end                                          as fulfillment_days
    from source
    where sls_ord_num is not null
      and sls_sales > 0
)

select * from renamed;
    ')


